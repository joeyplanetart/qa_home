# Turso 数据库（必填，线上 / 本地连 Turso 时）
TURSO_DATABASE_URL=libsql://qa-joeyplanetart.aws-us-west-2.turso.io
# 必须是「数据库 token」，不能用组织 API token
# 生成方式: turso db tokens create qa
# 或在 Turso 控制台 → 数据库 qa → Create Token
TURSO_AUTH_TOKEN=your-database-token-here

# 本地服务端口（可选）
PORT=8765

# GitHub API Token（可选，提高 Top10 抓取频率上限）
# GITHUB_TOKEN=ghp_xxx

# Vercel Cron 鉴权（线上部署时建议设置）
# CRON_SECRET=your-random-secret
